# Copy file này thành .env.local
# KHÔNG commit .env.local lên GitHub

# --- AI (chọn một provider) ---
# Mặc định: gemini. Đổi sang API tương thích OpenAI (Groq, OpenRouter, Together, Ollama qua URL):
# AI_PROVIDER=openai_compat
# OPENAI_COMPAT_API_KEY=gsk_...
# OPENAI_COMPAT_BASE_URL=https://api.groq.com/openai/v1
# OPENAI_COMPAT_MODEL=llama-3.1-8b-instant

# Gemini API — Miễn phí tại: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIza...

# Neon PostgreSQL — Miễn phí tại: https://neon.tech
# Dashboard → Project → Connection Details → Pooled connection
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require
